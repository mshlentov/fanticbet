APP_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=fanticbet
DB_PASSWORD=fanticbet
DB_NAME=fanticbet
DB_DSN=postgres://fanticbet:fanticbet@localhost:5432/fanticbet?sslmode=disable

JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_MINUTES=15
REFRESH_TTL_DAYS=30

ODDS_API_KEY=your-odds-api-key
# Имя букмекера должно совпадать со списком из GET /v3/bookmakers (Pinnacle там нет).
BOOKMAKER=1xbet
SPORTS=football,basketball

# Расписания воркеров (cron-спеки robfig/cron). На бесплатном тарифе Odds-API
# лимиты жёсткие (100 req/час): без батчинга OddsSyncWorker каждые 30 мин с окном
# 48ч = ~70 запросов за прогон, т.е. за час лимит вы́жен. Рекомендуемые значения:
# ODDS_SYNC_SCHEDULE=@every 1h, ODDS_SYNC_WINDOW_HOURS=24 (котировки за день, 20 запросов/час)
# SETTLEMENT_SCHEDULE: расчёт ставок по завершённым событиям (см. architecture.md §5).
# Каждый прогон делает по 1 запросу GetEvent на каждое начавшееся событие.
EVENT_SYNC_SCHEDULE=@every 1h
ODDS_SYNC_SCHEDULE=@every 1h
SETTLEMENT_SCHEDULE=@every 5m
ODDS_SYNC_WINDOW_HOURS=24

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:8080/api/v1/auth/yandex/callback

VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=http://localhost:8080/api/v1/auth/vk/callback

SIGNUP_BONUS=10000
BET_MIN=10
BET_MAX=10000
